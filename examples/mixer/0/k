dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.375;

boundaryField
{
    wall-part_3-solid
    {
        type            wallFunction;
        value           uniform 9;
    }
   in1
    {
       type            fixedValue;
        value           uniform 0.375;    
    }
    in2
    {
       type            fixedValue;
        value           uniform 0.375;
    }
    out
    {
         type            zeroGradient;
    }
    top
    {
        type            wallFunction;
        value           uniform 9;
   }
}


