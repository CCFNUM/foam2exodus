dimensions      [0 0 0 1 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    wall-part_3-solid
    {
        type            noSlip;
	value uniform (0 0 0);
    }
    in1
    {
        type        specifiedMagnitudeAndNormal;
	magnitude    2;
 	value uniform (0 0 0);
   }
    in2
    {
        type         specifiedMagnitudeAndNormal;
	magnitude     2;
	value uniform (0 0 0);

     }
    out
    {
        type            outlet;
	value uniform (0 0 0);
    }
    top
    {
        type            noSlip;
	value uniform (0 0 0);
    }

}

